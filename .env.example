# Copy to `.env` on the server (never commit real secrets).

# Public origin (no trailing slash). Baked into the SPA at image build time.
# After changing this, run: docker compose build web --no-cache
PUBLIC_ORIGIN=http://localhost

# WEB_PORT=8080

# Shared: FastAPI (backend) and stream server use OpenAI for the agent.
OPENAI_API_KEY=

OPENAI_MODEL=gpt-4o-mini

# Optional: require this value on /api/*, canvas WebSocket (?token= or headers), and POST /stream.
# Set the same value in the SPA as VITE_BACKEND_API_KEY (visible in the browser — pair with strict CORS).
# BACKEND_API_KEY=

# Background organizer: periodic OpenAI turn when the board looks messy (costs tokens when enabled).
PROACTIVE_ORGANIZER_ENABLED=false
PROACTIVE_ORGANIZER_INTERVAL_SEC=30
PROACTIVE_ORGANIZER_COOLDOWN_SEC=120

# Higgsfield image API — use KEY_ID:KEY_SECRET or separate key + secret (see backend README).
HIGGSFIELD_CREDENTIALS=
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=

HIGGSFIELD_IMAGE_MODEL_DEFAULT=higgsfield-ai/soul/standard
HIGGSFIELD_IMAGE_ASPECT_RATIO=1:1
HIGGSFIELD_IMAGE_RESOLUTION=720p

# Comma-separated browser origins. Must include your real site origin (scheme + host [+ port]).
# Use * only for local experiments (disables credentialed CORS on FastAPI).
# For Docker with HTTPS, set to your PUBLIC_ORIGIN, e.g. CORS_ALLOW_ORIGINS=https://example.com
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8000,http://localhost:8000
