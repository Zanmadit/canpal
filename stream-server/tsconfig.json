{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"baseUrl": ".",
		"paths": {
			"worker/*": ["../frontend/worker/*"],
			"shared/*": ["../frontend/shared/*"]
		}
	},
	"include": ["server.ts"]
}
